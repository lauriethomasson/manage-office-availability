# Copy this file to .env and fill in your key.
# Only used for the LLM fallback step, when a file doesn't match a known
# rule-based layout. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional locally. REQUIRED when deploying anywhere reachable by other
# people (see README's Deployment section) — gates the app behind
# yourapp.onrender.com/<this value> instead of the root URL. Leave unset
# for local dev to skip the token entirely. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(16))"
ACCESS_TOKEN=
